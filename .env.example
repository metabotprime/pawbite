# ─────────────────────────────────────────────────────────────
# PawBite environment variables
# Copy to .env.local and fill in. See docs/INTEGRATION.md for wiring.
# Anything NEXT_PUBLIC_* is exposed to the browser — never put secrets there.
# ─────────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # set to https://pawbite.com in Vercel production

# ── Commerce ──────────────────────────────────────────────────
# Pick ONE checkout path. The spec's recommendation is Shopify (it handles
# tax, fulfillment, and subscriptions out of the box for a DTC supplement brand).

# Option A — Shopify (Storefront API + native checkout)
# SHOPIFY_STORE_DOMAIN=pawbite.myshopify.com
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Subscriptions via a Shopify app (Recharge or Skio):
# SUBSCRIPTION_APP=skio
# SKIO_API_KEY=

# Option B — Stripe (custom cart + Stripe Checkout / Billing)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Email + lifecycle (Klaviyo) ───────────────────────────────
# Powers: newsletter signup, quiz email capture, and the $5-off / WELCOME discount.
# KLAVIYO_PRIVATE_API_KEY=
# NEXT_PUBLIC_KLAVIYO_PUBLIC_API_KEY=
# KLAVIYO_NEWSLETTER_LIST_ID=
# KLAVIYO_QUIZ_LIST_ID=

# ── Reviews (Stamped) ─────────────────────────────────────────
# STAMPED_PUBLIC_KEY=
# STAMPED_PRIVATE_KEY=
# STAMPED_STORE_HASH=

# ── Analytics ─────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_GA4_ID=

# ── Error tracking (optional — referenced in app/error.tsx) ───
# NEXT_PUBLIC_SENTRY_DSN=
